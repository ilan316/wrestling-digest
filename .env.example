# ── OPML ─────────────────────────────────────────────────────────────────────
# Path to the OPML file exported from Feedly (Settings → Import/Export → Export OPML)
# Default: looks for the .opml file in the same directory as this script.
# OPML_PATH=C:\path\to\your\feedly-export.opml

# Comma-separated category names to monitor (exactly as they appear in Feedly).
# Leave empty to monitor ALL categories.
# Example: CATEGORIES=News,Android,Wrestling
CATEGORIES=


# ── Claude API ───────────────────────────────────────────────────────────────
# Get your API key from: https://console.anthropic.com/
CLAUDE_API_KEY=your_claude_api_key_here


# ── Gmail ────────────────────────────────────────────────────────────────────
# Your Gmail address
GMAIL_USER=your@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# How to generate:
#   1. Go to: https://myaccount.google.com/security
#   2. Enable 2-Step Verification (if not already enabled)
#   3. Search for "App passwords" → Generate → Select "Mail"
#   4. Copy the 16-character password (spaces are optional)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to send the digest (defaults to GMAIL_USER if left empty)
RECIPIENT_EMAIL=your@gmail.com


# ── Behaviour ────────────────────────────────────────────────────────────────
# How many hours back to fetch articles (default: 24)
LOOKBACK_HOURS=24
